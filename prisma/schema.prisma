  appointment ClinicAppointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  portalLink  ClinicPatientPortalLink? @relation(fields: [portalLinkId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, patientId, createdAt])
  @@index([appointmentId, createdAt])
  @@map("clinic_patient_portal_requests")
}

model ClinicIntakeQuestion {
  id              String                   @id @default(cuid())
  tenantId        String
  procedureId     String
  prompt          String                   @db.Text
  helpText        String?                  @db.Text
  type            ClinicIntakeQuestionType @default(TEXT)
  required        Boolean                  @default(false)
  active          Boolean                  @default(true)
  sortOrder       Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  createdByUserId String?

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure        @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  responses ClinicIntakeResponse[]

  @@index([tenantId, procedureId, active, sortOrder])
  @@map("clinic_intake_questions")
}

model ClinicIntakeResponse {
  id             String                   @id @default(cuid())
  tenantId       String
  patientId      String
  appointmentId  String
  procedureId    String?
  questionId     String?
  promptSnapshot String                   @db.Text
  typeSnapshot   ClinicIntakeQuestionType
  answerText     String?                  @db.Text
  createdAt      DateTime                 @default(now()) @db.Timestamptz(6)

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient     ClinicPatient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment ClinicAppointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  procedure   ClinicProcedure?      @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  question    ClinicIntakeQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([tenantId, appointmentId, createdAt])
  @@index([tenantId, patientId, createdAt])
  @@index([questionId, createdAt])
  @@map("clinic_intake_responses")
}

