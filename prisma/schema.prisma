  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, acceptedAt])
  @@index([visitId, createdAt])
  @@map("clinic_consent_records")
}

model ClinicTreatmentPlan {
  id              String                    @id @default(cuid())
  tenantId        String
  patientId       String
  procedureId     String?
  title           String
  expectedSessions Int                     @default(1)
  cadenceDays     Int                      @default(14)
  status          ClinicTreatmentPlanStatus @default(ACTIVE)
  targetStartAt   DateTime?                @db.Date
  targetEndAt     DateTime?                @db.Date
  goals           String?                  @db.Text
  nextSteps       String?                  @db.Text
  outcomeNotes    String?                  @db.Text
  photoMilestones Json?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  createdByUserId String?

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient   ClinicPatient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  visits    ClinicVisit[]

  @@index([tenantId, patientId, status])
  @@index([tenantId, procedureId, status])
  @@map("clinic_treatment_plans")
}

model ClinicPatientReview {
  id                 String             @id @default(cuid())
  tenantId           String
  patientId          String
  appointmentId      String?
  visitId            String?
  reminderDeliveryId String?
  status             ClinicReviewStatus @default(REQUESTED)
  rating             Int?
  /// Internal feedback or triage notes. Not public-facing.
  privateNote        String?            @db.Text
  /// Candidate public review text. Staff decides if/when to publish externally.
  publicComment      String?            @db.Text
  requestedAt        DateTime?          @db.Timestamptz(6)
  repliedAt          DateTime?          @db.Timestamptz(6)
  publishedAt        DateTime?          @db.Timestamptz(6)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdByUserId    String?

  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient          ClinicPatient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment      ClinicAppointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  visit            ClinicVisit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  reminderDelivery ClinicReminderDelivery? @relation(fields: [reminderDeliveryId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, requestedAt])
  @@index([tenantId, rating])
  @@index([patientId, createdAt])
  @@index([appointmentId, createdAt])
  @@map("clinic_patient_reviews")
}

/// CRM / communication log (calls, WhatsApp, internal notes on the relationship).
model ClinicCrmActivity {
