  procedure ClinicProcedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  records   ClinicConsentRecord[]

  @@index([tenantId, active, title])
  @@index([tenantId, procedureId, active])
  @@map("clinic_consent_templates")
}

model ClinicConsentRecord {
  id                        String   @id @default(cuid())
  tenantId                  String
  patientId                 String
  templateId                String?
  procedureId               String?
  appointmentId             String?
  visitId                   String?
  templateTitleSnapshot     String
  templateBodySnapshot      String   @db.Text
  contraindicationsSnapshot String[] @default([])
  checkedItems              String[] @default([])
  patientNameSnapshot       String
  accepted                  Boolean  @default(false)
