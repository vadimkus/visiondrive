  SENT
  SKIPPED
  CANCELLED
}

enum ClinicBookingFunnelEventType {
  LINK_VIEW
  SERVICE_SELECTED
  SLOT_SELECTED
  FORM_STARTED
  FORM_SUBMITTED
  BOOKING_COMPLETED
}

enum ClinicTreatmentPlanStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ClinicPatientPortalRequestType {
  RESCHEDULE
  CANCEL
  MESSAGE
}

enum ClinicPatientPortalRequestStatus {
  OPEN
  REVIEWED
  CLOSED
}

