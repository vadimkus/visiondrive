/// In-person or telehealth encounter; attach before/after photos and payments.
model ClinicVisit {
  id                            String            @id @default(cuid())
  tenantId                      String
  patientId                     String
  appointmentId                 String?
  treatmentPlanId               String?
  visitAt                       DateTime          @db.Timestamptz(6)
  status                        ClinicVisitStatus @default(COMPLETED)
  chiefComplaint                String?           @db.Text
  procedureSummary              String?           @db.Text
  staffNotes                    String?           @db.Text
  /// Planned follow-up / what to do next (shown prominently on patient chart)
  nextSteps                     String?           @db.Text
  aftercareTemplateId           String?
  /// Patient-facing aftercare title captured at visit completion, so later template edits do not rewrite history.
  aftercareTitleSnapshot        String?
  aftercareTextSnapshot         String?           @db.Text
  aftercareDocumentNameSnapshot String?
  aftercareDocumentUrlSnapshot  String?           @db.Text
  aftercareSentAt               DateTime?         @db.Timestamptz(6)
  /// Set when procedure-linked inventory auto-consumption has been applied (idempotent).
  inventoryConsumedAt           DateTime?         @db.Timestamptz(6)
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient             ClinicPatient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment         ClinicAppointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  treatmentPlan       ClinicTreatmentPlan?       @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  aftercareTemplate   ClinicAftercareTemplate?   @relation(fields: [aftercareTemplateId], references: [id], onDelete: SetNull)
  media               ClinicPatientMedia[]
  payments            ClinicPatientPayment[]
  productSales        ClinicProductSale[]
  reviews             ClinicPatientReview[]
  packageRedemptions  ClinicPackageRedemption[]
  giftCardRedemptions ClinicGiftCardRedemption[]
  consentRecords      ClinicConsentRecord[]

  @@index([tenantId, visitAt])
  @@index([patientId, visitAt])
  @@index([treatmentPlanId, visitAt])
  @@index([aftercareTemplateId])
  @@index([tenantId, aftercareSentAt])
  @@map("clinic_visits")
}

/// Clinical photo (e.g. before/after). Stored as Postgres BYTEA and/or Vercel Blob (private pathname).
model ClinicPatientMedia {
  id                 String          @id @default(cuid())
  tenantId           String
  patientId          String
  visitId            String?
  kind               ClinicMediaKind
  mimeType           String
  caption            String?
  /// Capture protocol metadata (checked lighting/angle/background prompts, procedure snapshot, consent note).
  protocolJson       Json?
  /// Explicit staff marker that marketing/public-use consent was documented for this image.
  marketingConsent   Boolean         @default(false)
  marketingConsentAt DateTime?       @db.Timestamptz(6)
  /// Legacy / local-dev: raw bytes. Null when `blobPathname` is set.
  data               Bytes?
  /// Vercel Blob private pathname (use SDK `get` with token). Null when `data` is set.
  blobPathname       String?
  createdAt          DateTime        @default(now())
  createdByUserId    String?

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient ClinicPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit   ClinicVisit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([visitId])
  @@index([tenantId, marketingConsent])
  @@map("clinic_patient_media")
}

model ClinicPatientPayment {
  id                String              @id @default(cuid())
  tenantId          String
  patientId         String
  visitId           String?
  appointmentId     String?
  amountCents       Int
  discountCents     Int                 @default(0)
  discountRuleId    String?
  discountName      String?
  discountReason    String?             @db.Text
  feeCents          Int                 @default(0)
  processorFeeCents Int                 @default(0)
  currency          String              @default("AED")
  method            ClinicPaymentMethod @default(OTHER)
  status            ClinicPaymentStatus @default(PAID)
  reference         String?
  note              String?             @db.Text
  paidAt            DateTime            @db.Timestamptz(6)
  createdAt         DateTime            @default(now())
  createdByUserId   String?

  tenant                 Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient                ClinicPatient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit                  ClinicVisit?              @relation(fields: [visitId], references: [id], onDelete: SetNull)
  appointment            ClinicAppointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  discountRule           ClinicDiscountRule?       @relation(fields: [discountRuleId], references: [id], onDelete: SetNull)
  productSale            ClinicProductSale?
  giftCardRedemption     ClinicGiftCardRedemption?
  correctionsAsOriginal  ClinicPaymentCorrection[] @relation("OriginalPaymentCorrections")
  correctionAsAdjustment ClinicPaymentCorrection?  @relation("AdjustmentPaymentCorrection")

  @@index([tenantId, patientId, paidAt])
  @@index([appointmentId, paidAt])
  @@index([discountRuleId, paidAt])
  @@map("clinic_patient_payments")
}

model ClinicPriceQuote {
  id              String                 @id @default(cuid())
  tenantId        String
  patientId       String
  quoteNumber     String
  title           String
  status          ClinicPriceQuoteStatus @default(DRAFT)
  currency        String                 @default("AED")
  subtotalCents   Int                    @default(0)
  discountCents   Int                    @default(0)
  totalCents      Int                    @default(0)
  validUntil      DateTime?              @db.Date
  note            String?                @db.Text
  terms           String?                @db.Text
  sentAt          DateTime?              @db.Timestamptz(6)
  acceptedAt      DateTime?              @db.Timestamptz(6)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdByUserId String?

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient       ClinicPatient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdByUser User?                  @relation("ClinicPriceQuoteCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines         ClinicPriceQuoteLine[]

  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, quoteNumber])
  @@map("clinic_price_quotes")
}

model ClinicPriceQuoteLine {
  id             String   @id @default(cuid())
  tenantId       String
  quoteId        String
  procedureId    String?
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  totalCents     Int      @default(0)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote     ClinicPriceQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)

  @@index([tenantId, quoteId])
  @@index([procedureId])
  @@map("clinic_price_quote_lines")
}

model ClinicPaymentCorrection {
  id                  String                      @id @default(cuid())
  tenantId            String
  patientId           String
  originalPaymentId   String
  adjustmentPaymentId String?                     @unique
  type                ClinicPaymentCorrectionType
  amountCents         Int                         @default(0)
  currency            String                      @default("AED")
  method              ClinicPaymentMethod         @default(OTHER)
  reason              String
  note                String?                     @db.Text
  correctedAt         DateTime                    @default(now()) @db.Timestamptz(6)
  createdAt           DateTime                    @default(now())
  createdByUserId     String?

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient           ClinicPatient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
