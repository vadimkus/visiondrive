/// Browser Web Push subscriptions for clinic alerts (low stock). Requires VAPID env on server.
model ClinicWebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, tenantId])
  @@map("clinic_web_push_subscriptions")
}

/// Tenant-scoped practitioner preferences for language and alert channels.
model ClinicUserPreference {
  id                  String   @id @default(cuid())
  userId              String
  tenantId            String
  locale              String   @default("en")
  notifyPush          Boolean  @default(true)
  notifyEmail         Boolean  @default(true)
  notifyNewBooking    Boolean  @default(true)
  notifyCancelled     Boolean  @default(true)
  notifyRescheduled   Boolean  @default(true)
  notifyReminderDue   Boolean  @default(true)
  notifyReviewRequest Boolean  @default(true)
  notifyUnpaidVisit   Boolean  @default(true)
  notifyLowStock      Boolean  @default(true)
  notifyPackageExpiry Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("clinic_user_preferences")
}

/// Idempotency log for practitioner browser push notifications.
model ClinicPractitionerPushDelivery {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  kind      String
  sourceKey String
  title     String
  body      String   @db.Text
  url       String
  sentAt    DateTime @default(now()) @db.Timestamptz(6)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, kind, sourceKey])
  @@index([tenantId, sentAt])
  @@map("clinic_practitioner_push_deliveries")
}

// Rate limiting table for brute force protection
model RateLimit {
  key         String   @id // Format: "ruleName:identifier" (e.g., "login:192.168.1.1")
  count       Int      @default(0)
  windowStart DateTime @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([updatedAt]) // For cleanup queries
  @@map("rate_limits")
}
