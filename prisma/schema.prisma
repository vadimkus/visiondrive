}

model ClinicPatient {
  id             String   @id @default(cuid())
  tenantId       String
  firstName      String
  lastName       String
  middleName     String?
  dateOfBirth    DateTime @db.Date
  phone          String?
  email          String?
  homeAddress    String?  @db.Text
  area           String?
  accessNotes    String?  @db.Text
  category       String?
  tags           String[] @default([])
  referredByName String?
  referralNote   String?  @db.Text
  /// Staff-only; never expose on patient-facing PDF exports
  internalNotes  String?  @db.Text
  /// Structured intake / history (v1 object: allergies, medications, conditions, social)
  anamnesisJson  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant              Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments        ClinicAppointment[]
  visits              ClinicVisit[]
  media               ClinicPatientMedia[]
  payments            ClinicPatientPayment[]
  paymentCorrections  ClinicPaymentCorrection[]
  productSales        ClinicProductSale[]
  crmActivities       ClinicCrmActivity[]
  reviews             ClinicPatientReview[]
  packages            ClinicPatientPackage[]
  giftCardsPurchased  ClinicGiftCard[]             @relation("GiftCardBuyer")
  giftCardRedemptions ClinicGiftCardRedemption[]
  consentRecords      ClinicConsentRecord[]
  treatmentPlans      ClinicTreatmentPlan[]
  portalLinks         ClinicPatientPortalLink[]
  portalRequests      ClinicPatientPortalRequest[]
  intakeResponses     ClinicIntakeResponse[]
  priceQuotes         ClinicPriceQuote[]
  waitlistEntries     ClinicWaitlistEntry[]

  @@index([tenantId, lastName, firstName])
  @@index([tenantId, phone])
  @@index([tenantId, category])
  @@index([tenantId, referredByName])
  @@map("clinic_patients")
}

model ClinicProcedure {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  defaultDurationMin Int      @default(60)
  /// Hidden operational buffer after a procedure (cleanup, prep, travel, rest).
  bufferAfterMinutes Int      @default(0)
  basePriceCents     Int      @default(0)
  currency           String   @default("AED")
  active             Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments        ClinicAppointment[]
  stockItems          ClinicStockItem[]
  availabilityRules   ClinicAvailabilityRule[]
  patientPackages     ClinicPatientPackage[]
  consentTemplates    ClinicConsentTemplate[]
  consentRecords      ClinicConsentRecord[]
  aftercareTemplates  ClinicAftercareTemplate[]
  treatmentPlans      ClinicTreatmentPlan[]
  materials           ClinicProcedureMaterial[]
  bookingFunnelEvents ClinicBookingFunnelEvent[]
  intakeQuestions     ClinicIntakeQuestion[]
  intakeResponses     ClinicIntakeResponse[]
  priceQuoteLines     ClinicPriceQuoteLine[]
  waitlistEntries     ClinicWaitlistEntry[]

  @@index([tenantId, active, name])
  @@map("clinic_procedures")
}

model ClinicAppointment {
  id                        String                  @id @default(cuid())
  tenantId                  String
  patientId                 String
  procedureId               String?
  startsAt                  DateTime                @db.Timestamptz(6)
  endsAt                    DateTime?               @db.Timestamptz(6)
  status                    ClinicAppointmentStatus @default(SCHEDULED)
  source                    ClinicAppointmentSource @default(MANUAL)
  /// Hidden occupied time after the appointment. Used for conflict checks, not shown as service duration.
  bufferAfterMinutes        Int                     @default(0)
  /// Travel/prep time before a home visit. Used for conflict checks and route planning.
  travelBufferBeforeMinutes Int                     @default(0)
  /// Travel time after a home visit. Used for conflict checks and route planning.
  travelBufferAfterMinutes  Int                     @default(0)
  locationAddress           String?                 @db.Text
  locationArea              String?
  locationNotes             String?                 @db.Text
  titleOverride             String?
  /// Required when staff intentionally books through a conflict, blocked time, or outside working hours.
  overrideReason            String?                 @db.Text
  cancelReason              String?                 @db.Text
  confirmedAt               DateTime?               @db.Timestamptz(6)
  arrivedAt                 DateTime?               @db.Timestamptz(6)
  completedAt               DateTime?               @db.Timestamptz(6)
  /// Doctor-only appointment / scheduling notes
  internalNotes             String?                 @db.Text
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  tenant                Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient               ClinicPatient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure             ClinicProcedure?             @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  visits                ClinicVisit[]
  events                ClinicAppointmentEvent[]
  reviews               ClinicPatientReview[]
  packageRedemptions    ClinicPackageRedemption[]
  giftCardRedemptions   ClinicGiftCardRedemption[]
  consentRecords        ClinicConsentRecord[]
  payments              ClinicPatientPayment[]
  productSales          ClinicProductSale[]
  bookingFunnelEvents   ClinicBookingFunnelEvent[]
  portalRequests        ClinicPatientPortalRequest[]
  intakeResponses       ClinicIntakeResponse[]
  bookedWaitlistEntries ClinicWaitlistEntry[]        @relation("WaitlistBookedAppointment")

  @@index([tenantId, startsAt])
  @@index([patientId, startsAt])
  @@map("clinic_appointments")
}

model ClinicAppointmentEvent {
  id              String                     @id @default(cuid())
  tenantId        String
  appointmentId   String
  type            ClinicAppointmentEventType
  message         String?                    @db.Text
  before          Json?
  after           Json?
  createdAt       DateTime                   @default(now()) @db.Timestamptz(6)
  createdByUserId String?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment ClinicAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdBy   User?             @relation("ClinicAppointmentEventActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([appointmentId, createdAt])
  @@map("clinic_appointment_events")
}

model ClinicWaitlistEntry {
  id                  String               @id @default(cuid())
  tenantId            String
  patientId           String
  procedureId         String?
  status              ClinicWaitlistStatus @default(OPEN)
  priority            Int                  @default(2)
  earliestAt          DateTime?            @db.Timestamptz(6)
  latestAt            DateTime?            @db.Timestamptz(6)
  preferredDays       String[]             @default([])
  preferredTimeOfDay  String?
  note                String?              @db.Text
  lastContactedAt     DateTime?            @db.Timestamptz(6)
  bookedAppointmentId String?
  createdByUserId     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient           ClinicPatient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure         ClinicProcedure?   @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  bookedAppointment ClinicAppointment? @relation("WaitlistBookedAppointment", fields: [bookedAppointmentId], references: [id], onDelete: SetNull)
  createdBy         User?              @relation("ClinicWaitlistEntryCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, patientId])
  @@index([tenantId, procedureId])
  @@map("clinic_waitlist_entries")
}

model ClinicAvailabilityRule {
  id                  String   @id @default(cuid())
  tenantId            String
  /// Optional procedure-specific override. Null means general practice availability.
  procedureId         String?
  /// 1 = Monday, 7 = Sunday. Matches Practice OS week views.
  dayOfWeek           Int
  startMinutes        Int
  endMinutes          Int
  /// FIXED = fixed slot interval; DYNAMIC = step by selected service duration + buffer.
  slotMode            String   @default("FIXED")
  slotIntervalMinutes Int      @default(30)
  minLeadMinutes      Int      @default(120)
  active              Boolean  @default(true)
  label               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure? @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@index([tenantId, dayOfWeek, active])
  @@index([tenantId, procedureId, dayOfWeek, active])
  @@map("clinic_availability_rules")
}

model ClinicBlockedTime {
  id              String   @id @default(cuid())
  tenantId        String
  startsAt        DateTime @db.Timestamptz(6)
  endsAt          DateTime @db.Timestamptz(6)
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startsAt])
  @@map("clinic_blocked_times")
}

model ClinicReminderTemplate {
  id        String                @id @default(cuid())
  tenantId  String
  kind      ClinicReminderKind
  channel   ClinicReminderChannel @default(WHATSAPP)
  name      String
  body      String                @db.Text
  active    Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind, channel])
  @@index([tenantId, active])
  @@map("clinic_reminder_templates")
}

model ClinicReminderDelivery {
  id              String                @id @default(cuid())
  tenantId        String
  appointmentId   String?
  patientId       String?
  kind            ClinicReminderKind
  channel         ClinicReminderChannel @default(WHATSAPP)
  status          ClinicReminderStatus  @default(SCHEDULED)
  scheduledFor    DateTime              @db.Timestamptz(6)
  preparedAt      DateTime?             @db.Timestamptz(6)
  sentAt          DateTime?             @db.Timestamptz(6)
  body            String                @db.Text
  whatsappUrl     String?               @db.Text
  error           String?               @db.Text
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews ClinicPatientReview[]

  @@index([tenantId, status, scheduledFor])
  @@index([appointmentId, createdAt])
  @@index([patientId, createdAt])
  @@map("clinic_reminder_deliveries")
}

model ClinicBookingFunnelEvent {
  id            String                       @id @default(cuid())
  tenantId      String
  sessionId     String
  eventType     ClinicBookingFunnelEventType
  procedureId   String?
  appointmentId String?
  startsAt      DateTime?                    @db.Timestamptz(6)
  occurredAt    DateTime                     @default(now()) @db.Timestamptz(6)
  referrer      String?                      @db.Text
  userAgent     String?                      @db.Text
  metadata      Json?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procedure   ClinicProcedure?   @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  appointment ClinicAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventType, occurredAt])
  @@index([tenantId, sessionId, occurredAt])
  @@index([procedureId, occurredAt])
  @@map("clinic_booking_funnel_events")
}

model ClinicPatientPortalLink {
  id              String    @id @default(cuid())
  tenantId        String
  patientId       String
  tokenHash       String    @unique
  tokenLastFour   String
  expiresAt       DateTime  @db.Timestamptz(6)
  revokedAt       DateTime? @db.Timestamptz(6)
  lastAccessedAt  DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now())
  createdByUserId String?

  tenant    Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient   ClinicPatient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User?                        @relation("ClinicPatientPortalLinkCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  requests  ClinicPatientPortalRequest[]

  @@index([tenantId, patientId, revokedAt])
  @@index([tenantId, expiresAt])
  @@map("clinic_patient_portal_links")
}

model ClinicPatientPortalRequest {
  id            String                           @id @default(cuid())
  tenantId      String
  patientId     String
  appointmentId String?
  portalLinkId  String?
  type          ClinicPatientPortalRequestType
  status        ClinicPatientPortalRequestStatus @default(OPEN)
  message       String                           @db.Text
  preferredTime String?                          @db.Text
  createdAt     DateTime                         @default(now()) @db.Timestamptz(6)
