  patientId       String
  type            ClinicCrmActivityType @default(NOTE)
  body            String                @db.Text
  occurredAt      DateTime              @db.Timestamptz(6)
  createdAt       DateTime              @default(now())
  createdByUserId String?

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient ClinicPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, occurredAt])
  @@map("clinic_crm_activities")
}

enum ClinicStockMovementType {
  RECEIPT
  ADJUSTMENT
  CONSUMPTION
  RETURN
}

enum ClinicStockCountStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum ClinicStockVarianceReason {
  COUNT_CORRECTION
  EXPIRED
  DAMAGED
  LOST
  FOUND
  OTHER
}

/// Consumables / retail stock per practice. Movements adjust quantityOnHand.
model ClinicStockItem {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  sku              String?
  unit             String   @default("unit")
  quantityOnHand   Int      @default(0)
  /// Alert when active and quantityOnHand <= reorderPoint (if reorderPoint > 0).
  reorderPoint     Int      @default(0)
  active           Boolean  @default(true)
  notes            String?  @db.Text
  /// Optional link to a procedure this item is typically consumed for.
  procedureId      String?
  /// Scannable code (distinct from sku); optional unique per tenant when set.
  barcode          String?
  /// When visit completes with linked procedure, deduct this many units (0 = disabled).
  consumePerVisit  Int      @default(0)
  /// Last time a low-stock email/push was sent (24h cooldown).
  lowStockNotifiedAt DateTime? @db.Timestamptz(6)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  movements ClinicStockMovement[]
  purchaseOrderLines ClinicPurchaseOrderLine[]
  procedureMaterials ClinicProcedureMaterial[]
  stockCountLines ClinicStockCountLine[]

  @@index([tenantId, active, name])
  @@index([tenantId, procedureId])
  @@index([tenantId, barcode])
  @@index([tenantId, sku])
  @@map("clinic_stock_items")
}

model ClinicProcedureMaterial {
  id              String   @id @default(cuid())
  tenantId        String
  procedureId     String
  stockItemId     String
  quantityPerVisit Int     @default(1)
  unitCostCents   Int      @default(0)
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  note            String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procedure ClinicProcedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  stockItem ClinicStockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([procedureId, stockItemId])
  @@index([tenantId, procedureId, active])
  @@index([tenantId, stockItemId])
  @@map("clinic_procedure_materials")
}

model ClinicStockMovement {
  id              String                  @id @default(cuid())
  tenantId        String
  stockItemId     String
  type            ClinicStockMovementType
  /// Positive adds stock; negative removes (validated so on-hand never below zero).
  quantityDelta   Int
  note            String?                 @db.Text
  reference       String?
  createdAt       DateTime                @default(now())
  createdByUserId String?

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockItem ClinicStockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([stockItemId, createdAt])
  @@map("clinic_stock_movements")
}

model ClinicStockCountSession {
  id                String                 @id @default(cuid())
  tenantId          String
  title             String
  status            ClinicStockCountStatus @default(DRAFT)
  countedAt         DateTime               @default(now()) @db.Timestamptz(6)
  finalizedAt       DateTime?              @db.Timestamptz(6)
  note              String?                @db.Text
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  createdByUserId   String?
  finalizedByUserId String?

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  ClinicStockCountLine[]

  @@index([tenantId, status, countedAt])
  @@map("clinic_stock_count_sessions")
}

model ClinicStockCountLine {
  id               String                     @id @default(cuid())
  tenantId         String
  sessionId        String
  stockItemId      String
  expectedQuantity Int
  countedQuantity  Int?
  varianceQuantity Int                       @default(0)
  reason           ClinicStockVarianceReason?
  note             String?                   @db.Text
  movementId       String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session   ClinicStockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stockItem ClinicStockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stockItemId])
  @@index([tenantId, stockItemId])
  @@index([tenantId, sessionId])
  @@map("clinic_stock_count_lines")
}

enum ClinicPurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model ClinicPurchaseOrder {
  id           String                    @id @default(cuid())
  tenantId     String
  supplierName String
  status       ClinicPurchaseOrderStatus @default(DRAFT)
  reference    String?
  notes        String?                   @db.Text
  orderedAt    DateTime                  @default(now()) @db.Timestamptz(6)
  expectedAt   DateTime?                 @db.Timestamptz(6)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  ClinicPurchaseOrderLine[]

  @@index([tenantId, orderedAt])
  @@map("clinic_purchase_orders")
}

model ClinicPurchaseOrderLine {
  id               String @id @default(cuid())
  purchaseOrderId  String
  stockItemId      String
  quantityOrdered  Int
  quantityReceived Int    @default(0)
  unitCostCents    Int?

  purchaseOrder ClinicPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     ClinicStockItem      @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([stockItemId])
  @@map("clinic_purchase_order_lines")
}

/// Browser Web Push subscriptions for clinic alerts (low stock). Requires VAPID env on server.
model ClinicWebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, tenantId])
  @@map("clinic_web_push_subscriptions")
}

// Rate limiting table for brute force protection
model RateLimit {
  key         String   @id // Format: "ruleName:identifier" (e.g., "login:192.168.1.1")
  count       Int      @default(0)
  windowStart DateTime @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

