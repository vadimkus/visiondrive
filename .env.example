# =============================================================================
# VisionDrive Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Database (at least one required)
# Checked in order: VISIONDRIVE_DATABASE_URL → PRISMA_DATABASE_URL → POSTGRES_URL → DATABASE_URL
# Vercel Postgres: add the integration to the project, then use the env vars Vercel injects
# (often POSTGRES_URL). You can copy the pooled URL into VISIONDRIVE_DATABASE_URL if needed.
# Local Docker: docker compose up -d → postgresql://visiondrive:visiondrive@localhost:5432/visiondrive?schema=public
# See docs/clinic/SETUP_LOCAL.md
VISIONDRIVE_DATABASE_URL=
# PRISMA_DATABASE_URL=
# POSTGRES_URL=
# DATABASE_URL=

# Authentication
JWT_SECRET=              # Required in production — used for portal auth tokens

# Practice console (/login → /clinic) — optional seed users for `npm run db:seed`
# Use strong passwords (see lib/password-policy.ts): 12+ chars, upper, lower, number, special, no sequences.
# CLINIC_VADIM_EMAIL=
# CLINIC_VADIM_PASSWORD=
# CLINIC_IRYNA_EMAIL=
# CLINIC_IRYNA_PASSWORD=
# Dev only: allow short passwords in seed (never in production)
# CLINIC_SEED_ALLOW_WEAK_PASSWORD=true

# Smart Kitchen (AWS)
SMART_KITCHEN_API_URL=   # AWS API Gateway URL (defaults to UAE prod endpoint)
KITCHEN_JWT_SECRET=      # JWT secret for kitchen portal token verification
SMART_KITCHEN_USE_MOCK=  # Set to "true" to use mock data instead of AWS API

# Mapbox (maps in portal)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Contact Form Email (optional — falls back to server logs if not set)
RESEND_API_KEY=          # Resend.com API key for contact form emails

# Cron Jobs
CRON_SECRET=             # Secret token for authenticating cron job requests

# SSL
STRICT_SSL_VALIDATION=   # Set to "true" to enforce strict SSL on DB connections

# Node
NODE_ENV=development     # Automatically set by Vercel/Next.js in production
